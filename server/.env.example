# ======================================================================
# Server environment variables — copy to `.env` and fill in LLM keys.
# Everything runs locally: SQLite DB, local `uploads/` dir, no Docker.
# ======================================================================

# ---- App ----
APP_ENV=development
APP_DEBUG=true
APP_CORS_ORIGINS=http://localhost:5173

# ---- Database ----
# Default is a SQLite file in the `server/` directory.
# To use local Postgres later, change to: postgresql+psycopg://user:pw@localhost:5432/bra_tool
DATABASE_URL=sqlite:///./bra_tool.db

# ---- Local file storage ----
# Raw uploads and exports are saved under these folders relative to `server/`.
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# ---- LLM providers ----
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ---- Default models per agent (can be overridden at runtime via /settings) ----
LLM_ANALYSER_MODEL=gpt-4o
LLM_DISCOVERY_MODEL=gpt-4o
LLM_ARCHITECTURE_MODEL=gpt-4o
LLM_SPRINT_MODEL=gpt-4o

# ---- Observability (optional) ----
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=bra-tool

# ---- Uploads ----
MAX_UPLOAD_MB=50
